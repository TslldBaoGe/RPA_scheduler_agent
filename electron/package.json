{
  "name": "rpa-agent",
  "version": "1.0.0",
  "description": "RPA Scheduler Agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "author": "RPA Scheduler",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.rpa.scheduler.agent",
    "productName": "RPA-Agent",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "agent-core.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "renderer/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "renderer/icon.ico",
      "uninstallerIcon": "renderer/icon.ico",
      "installerHeaderIcon": "renderer/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RPA Agent"
    }
  }
}
